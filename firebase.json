{
  "hosting": {
    "public": "public",
    "rewrites": [
      {
        "source": "/index",
        "destination": "/index.html"
      },
      {
        "source": "/learn",
        "destination": "/learn.html"
      },
      {
        "source": "/store",
        "destination": "/store.html"
      },
      {
        "source": "/create",
        "destination": "/create.html"
      }
    ] 
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
